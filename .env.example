# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Django core
SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=your-ec2-ip,yourdomain.com

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Database (set DB_ENGINE=sqlite3 for local dev, postgresql for production)
DB_ENGINE=postgresql
DB_NAME=midrus_db
DB_USER=midrus_user
DB_PASSWORD=strong-database-password-here
DB_HOST=localhost
DB_PORT=5432

# HTTPS — set to True only after SSL/nginx is configured
SECURE_SSL_REDIRECT=False
# Set to 31536000 (1 year) once the site is stable on HTTPS
SECURE_HSTS_SECONDS=0

# Email / SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
# Gmail: use an App Password, not your real password
# Generate at: myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=MIDRUS <your-gmail@gmail.com>
FRONTEND_URL=https://midrus.vercel.app
