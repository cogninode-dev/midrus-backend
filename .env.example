# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ─── Django core ─────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=your-ec2-ip,yourdomain.com

# ─── Database ────────────────────────────────────────────────────────────────
# Set DB_ENGINE=sqlite3 for local dev; postgresql for production
DB_ENGINE=postgresql
DB_NAME=midrus_db
DB_USER=midrus_user
DB_PASSWORD=strong-database-password-here
DB_HOST=localhost
DB_PORT=5432

# ─── HTTPS / Security ────────────────────────────────────────────────────────
# Set SECURE_SSL_REDIRECT=True only if nginx is NOT handling the redirect itself
SECURE_SSL_REDIRECT=False
# Set to 31536000 (1 year) once the site is stable on HTTPS
SECURE_HSTS_SECONDS=0
# These default to "not DEBUG" — set explicitly for production clarity
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ─── CORS / CSRF ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# ─── Email / SMTP ────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
# Gmail: use an App Password, not your real password
# Generate at: myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=MIDRUS <your-gmail@gmail.com>
ADMIN_EMAIL=your-admin@gmail.com

# ─── Gunicorn (Procfile) ─────────────────────────────────────────────────────
WEB_CONCURRENCY=3
PORT=8000
